# Rust build output
AnkiCore/target/

# Built engine binary (regenerate with AnkiCore/build-xcframework.sh)
AnkiCore/AnkiCore.xcframework/
AnkiCore/smoketest

# SwiftPM
.build/
**/.build/
Package.resolved

# Xcode / XcodeGen (project is generated from project.yml)
AnkiApp/AnkiSpeedrun.xcodeproj/
AnkiApp/build/
DerivedData/
*.xcuserstate
*.xcuserdatad

# Local environment / secrets
.env

# Scratch / screenshots (but keep bundled image assets in the asset catalog)
*.png
!**/Assets.xcassets/**/*.png
# Never drop raster assets bundled into the SvelteKit web app
!**/Resources/sveltekit/**
# Keep the bundled reviewer runtime (reviewer.js, MathJax engine + fonts, CSS)
!**/Resources/reviewer/**

.DS_Store
